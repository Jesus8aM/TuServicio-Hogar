<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Confirmar solicitud"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvDireccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📍 Dirección"
        android:textSize="14sp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/tvDescripcion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔧 Descripción del servicio"
        android:textSize="14sp"
        android:alpha="0.7"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿Cómo pagarás al técnico?"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnEfectivo"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="💵 Pagar en efectivo"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnTarjeta"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="💳 Pagar con tarjeta"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnCancelar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Cancelar"
        style="@style/Widget.MaterialComponents.Button.TextButton"/>

</LinearLayout>