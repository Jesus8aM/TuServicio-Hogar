<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTituloServicio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Servicio en curso"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tvClienteServicio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvTecnicoServicio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvCategoriaServicio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvDescripcionServicio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvDireccionServicio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resumen de cobro"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvMontoBase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tarifa base: $0.00"
            android:textSize="16sp"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvMontoAdicional"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monto adicional: $0.00"
            android:textSize="16sp"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvMontoTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total: $0.00"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvComisionApp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Comisión app: $0.00"
            android:textSize="14sp"
            android:alpha="0.7"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvGananciaTecnico"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ganancia técnico: $0.00"
            android:textSize="14sp"
            android:alpha="0.7"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:id="@+id/layoutMontoTecnico"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Monto adicional por materiales o trabajo extra">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMontoAdicional"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal" />

            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnEnviarMonto"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="ENVIAR MONTO"
                android:layout_marginTop="12dp"/>

        </LinearLayout>

        <Button
            android:id="@+id/btnAceptarMonto"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="ACEPTAR MONTO"
            android:visibility="gone"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnTerminarServicio"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="TERMINAR SERVICIO"
            android:visibility="gone"/>

    </LinearLayout>

</ScrollView>